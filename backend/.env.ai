# ============================================================
#  AI Service Environment Variables
# ============================================================

# Database (shared PostgreSQL with TimescaleDB)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/erp_aluminium

# Redis (shared Redis instance, using DB 1 for AI isolation)
REDIS_URL=redis://redis:6379/1

# Models storage
MODELS_PATH=/app/models

# Python
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
